<?xml version="1.0" encoding="utf-8"?>
<robot name="depth_camera" xmlns:xacro="http://ros.org/wiki/xacro" >
  <xacro:property name="M_PI"   value="3.1415926535897931"/>
  <link
    name="depth_cam_link">
    <inertial>
      <origin
        xyz="0.000254340878565573 0.00268031633059271 -0.00569075323067275"
        rpy="0 0 0" />
      <mass
        value="0.227980406655671" />
      <inertia
        ixx="4.8473190489023E-05"
        ixy="8.29314946303069E-09"
        ixz="-5.0952649884666E-09"
        iyy="0.000408820027771005"
        iyz="-1.36580074559918E-07"
        izz="0.000429553467348926" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 1.57" />
      <geometry>
        <mesh
          filename="package://robotics_subject/models/jetauto/depth_camera_link.stl" />
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 1.57" />
      <geometry>
        <mesh
          filename="package://robotics_subject/models/jetauto/depth_camera_link_collision.stl" />
      </geometry>
    </collision>
  </link>
  <joint
    name="joint1"
    type="revolute">
    <origin
      xyz="0.0288581470059471 0 0.202093286991617"
      rpy="0 0 1.5708" />
    <parent
      link="base_link" />
    <child
      link="depth_cam_link" />
    <axis
      xyz="0 0 1" />
    <limit
      lower="-2.09"
      upper="2.09"
      effort="1000"
      velocity="10" />
  </joint>
  <link name="depth_cam_frame" />
  <joint
    name="depth_cam_joint_sim"
    type="fixed">
    <origin xyz="0 0 0" rpy="${-M_PI/2} 0 ${-M_PI/2}" />
    <parent link="depth_cam_link" />
    <child link="depth_cam_frame" />
  </joint>

  <gazebo reference="depth_cam_link">
    <sensor name="camera" type="camera">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <visualize>false</visualize>
      <camera name="front_camera">
        <horizontal_fov>1.2</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>8.0</far>
        </clip>
      </camera>
      <plugin name="gazebo_ros_camera" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>~/image_raw:=/jetauto/camera/image_raw</remapping>
          <remapping>~/camera_info:=/jetauto/camera/camera_info</remapping>
        </ros>
        <frame_name>depth_cam_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>
</robot>